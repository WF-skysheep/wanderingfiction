{
  "name": "ocr-deepseek-translator",
  "version": "1.2.0",
  "private": true,
  "description": "Cloudflare Pages frontend + standalone Worker backend for DeepSeek OCR translation",
  "scripts": {
    "dev": "wrangler pages dev .",
    "deploy": "wrangler pages deploy .",
    "worker:dev": "wrangler dev --config wrangler.worker.toml",
    "worker:deploy": "wrangler deploy --config wrangler.worker.toml",
    "wf:migrate": "node wf-server/migrate.js",
    "wf:dev": "node wf-server/server.js",
    "wf:test": "node --test wf-server/tests/*.test.js"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "wrangler": "^4.38.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "uuid": "^13.0.0"
  }
}
