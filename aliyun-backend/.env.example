# 服务端口
PORT=8788

# SQLite 文件路径
WF_DB_PATH=/var/www/wanderingfiction/aliyun-backend/data/wf.db

# CORS 允许来源（逗号分隔）
# 建议至少包含你的前端域名，例如：https://wanderingfiction.xyz
CORS_ORIGIN=https://wanderingfiction.xyz
WF_CORS_ORIGIN=https://wanderingfiction.xyz

# 登录 cookie 策略
# 若前端与后端同主域（wanderingfiction.xyz / api.wanderingfiction.xyz），可用 lax
# 若前端在 github.io 等跨站域，改为 none 并保持 secure=true
WF_COOKIE_SAMESITE=lax
WF_COOKIE_SECURE=true

# 管理员用户名（首次注册该用户名会标记为 admin）
WF_ADMIN_USERNAME=admin

# 鉴权密钥（预留）
AUTH_SECRET=replace_with_long_random_string

# AI Provider: mock | deepseek | openai
WF_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_with_deepseek_key
OPENAI_API_KEY=

# 网易云 cookie（播放器后端使用）
NETEASE_COOKIE=
